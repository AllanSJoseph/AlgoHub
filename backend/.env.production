# Server Config
PORT=3000

# MongoDB Server Config
DB_CONNECT_STRING=your_mongodb_connection_string

# JWT Secret Key
JWT_KEY=your_jwt_secret_key

# Judge0 Config
JUDGE0_URL=http://judge0:2358

# Redis Config
REDIS_USERNAME=default
REDIS_HOST=redis_app
REDIS_PASS=
